# Shared SQL Server connection string used by the .NET services.
HOMEDEFENDER_DB_CONNECTION_STRING=Server=localhost;Database=detection_sys_db;Integrated Security=True;TrustServerCertificate=True;

# pymssql settings used by the Python AI process.
HOMEDEFENDER_DB_SERVER=localhost
HOMEDEFENDER_DB_USER=home_defender
HOMEDEFENDER_DB_PASSWORD=change-me
HOMEDEFENDER_DB_NAME=detection_sys_db

# Camera registration service.
HOMEDEFENDER_REGISTRATION_HOST=0.0.0.0
HOMEDEFENDER_REGISTRATION_PORT=25361

# SRS and video storage.
HOMEDEFENDER_SRS_STREAMS_API=http://127.0.0.1:1985/api/v1/streams
HOMEDEFENDER_RTMP_BASE_URL=rtmp://127.0.0.1/live
HOMEDEFENDER_VIDEO_ROOT=C:\HomeDefender\live

# Python, FFmpeg, and process lifecycle settings.
HOMEDEFENDER_PYTHON_HOME=C:\path\to\python39
HOMEDEFENDER_PYTHON_EXECUTABLE=C:\path\to\python39\python.exe
HOMEDEFENDER_CORE_PATH=C:\path\to\HomeDefender\Core
HOMEDEFENDER_FFMPEG_EXECUTABLE=ffmpeg
HOMEDEFENDER_PROCESS_START_DELAY_MS=7000
