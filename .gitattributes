* text=auto

*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.razor text eol=crlf
*.cshtml text eol=crlf
*.cpp text eol=lf
*.h text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.txt text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.pdb binary
*.pdf binary

# Model files are stored through Git LFS.
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.engine filter=lfs diff=lfs merge=lfs -text
*.tflite filter=lfs diff=lfs merge=lfs -text

# Keep bundled third-party sources from dominating GitHub language statistics.
Core/yolov8/** linguist-vendored
Core/trackers/** linguist-vendored
BlazorApp1/wwwroot/js/hls.js* linguist-vendored
BlazorApp1/wwwroot/js/mpegts.js* linguist-vendored

